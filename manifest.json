{
  "manifest_version": 3,
  "name": "AI Rewards Wallet",
  "version": "1.0",
  "description": "Earn rewards for your AI research!",
  "permissions": ["storage", "notifications", "tabs"],
  "host_permissions": [
    "https://*.chatgpt.com/*",
    "https://chatgpt.com/*",
    "https://*.claude.ai/*",
    "https://claude.ai/*",
    "https://*.gemini.google.com/*",
    "https://gemini.google.com/*",
    "https://*.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://*.deepseek.com/*",
    "https://deepseek.com/*",
    "https://*.use.ai/*",
    "https://use.ai/*",
    "https://ai-rewards-wallet-production.up.railway.app/*",
    "https://*.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chatgpt.com/*",
        "https://chatgpt.com/*",
        "https://*.claude.ai/*",
        "https://claude.ai/*",
        "https://*.gemini.google.com/*",
        "https://gemini.google.com/*",
        "https://*.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://*.deepseek.com/*",
        "https://deepseek.com/*",
        "https://*.use.ai/*",
        "https://use.ai/*"
      ],
      "js": ["content.js"]
    }
  ]
}
